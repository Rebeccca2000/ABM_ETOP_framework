@article{Guzman2018,
  author = {Guzman, Luis A. and Oviedo, Daniel},
  title = {Accessibility, affordability and equity: Assessing 'pro-poor' public transport subsidies in {Bogotá}},
  journal = {Transport Policy},
  volume = {68},
  pages = {37--51},
  year = {2018},
  doi = {10.1016/j.tranpol.2018.04.012},
  publisher = {Elsevier},
  abstract = {Transport subsidies are often designed to address social inequalities. While a significant emphasis has been placed in the design of subsidies targeting those most in need, less attention is paid to the appraisal of the underlying social policies behind such subsidies. This paper develops a framework for assessing the social impacts of transport subsidies, outlining indicators for evaluating effects on affordability, accessibility, targeting, cost-efficiency and demand. The framework is applied to the case of Bogotá's pro-poor public transit subsidy introduced in 2014, which targets certain disadvantaged population groups, offering reduced fares for the local Bus Rapid Transit and other components of the public transport system. Results suggest that despite having positive impacts on target population, the current subsidy in Bogotá has different effects on accessibility, affordability, targeting, cost-efficiency, and demand-related variables depending on the socioeconomic characteristics of the population and geographic location in the city.},
  keywords = {transport subsidies, social equity, pro-poor policies, public transport, Bogotá}
}

